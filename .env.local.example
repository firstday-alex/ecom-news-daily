# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (get at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI.org key (free tier: 100 req/day — register at newsapi.org)
NEWS_API_KEY=your-newsapi-key

# Secret to protect the cron endpoint — set to any random string
# Must also be set in Vercel dashboard under Settings > Environment Variables
CRON_SECRET=generate-a-random-secret-here

# ── Upstash Redis (auto-provided by Vercel Integration) ───────────────────────
# After linking an Upstash Redis database in your Vercel project, these are
# automatically injected into your environment. For local dev, copy them from
# the Upstash dashboard or Vercel > Settings > Environment Variables.

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Optional ──────────────────────────────────────────────────────────────────

# Bing News Search API key (Azure Cognitive Services — free 1000 req/month)
# Leave blank to disable Bing as a source
BING_SEARCH_API_KEY=
